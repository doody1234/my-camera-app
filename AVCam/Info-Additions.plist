<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required: camera access for AVCaptureSession -->
    <key>NSCameraUsageDescription</key>
    <string>This app needs camera access to capture 10-bit HDR video.</string>

    <!-- Required: microphone access for the audio AVCaptureDeviceInput -->
    <key>NSMicrophoneUsageDescription</key>
    <string>This app needs microphone access to record audio with your video.</string>

    <!-- Optional/bonus: only needed once you add "save to Photos" -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>This app needs access to save recorded video to your Photo Library.</string>
</dict>
</plist>
